#: ../../hotspot.rst:105 1f371f71b5d84667a88143faa7d43194
msgid "Edit the UCI configuration file with the following commands:"
msgstr "Modificare il file di configurazione UCI con i seguenti comandi:"

#: ../../hotspot.rst:112 797b982441144b1fa861030cd2384438
msgid "Save the changes with the following command:"
msgstr "Salvare le modifiche con il seguente comando:"

#: ../../hotspot.rst:118 4ed010d04e76456d8ecd05dfd3048da2
msgid "Restart the dedalo service with:"
msgstr "Riavviare il servizio dedalo con:"

#: ../../hotspot.rst:125 d7ba6a5fb53a4bf498e6e49fe502703a
msgid "Restore default DNS settings"
