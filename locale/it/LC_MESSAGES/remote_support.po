msgstr "Copiare ``ID sessione`` e condividerlo con il team di supporto."

#: ../../remote_support.rst:19 88c79e0e74f240ad971b81768b79657a
msgid "Session management"
msgstr "Gestione delle sessioni"

#: ../../remote_support.rst:21 3dae7bd52d2a49d28ef8ae211668e871
