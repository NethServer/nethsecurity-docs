"The remote support must be started and stopped by the firewall "
"administrator."
msgstr ""
"Il supporto remoto deve essere avviato e interrotto dall'amministratore del "
"firewall."

#: ../../remote_support.rst:24 f8a9d38a7b154c6ebc0dbd48c955962f
msgid "Starting a session"
msgstr "Avvio di una sessione"

#: ../../remote_support.rst:26 eb7d7e1743e4484e9df5cd4622b3acb4
msgid "To start a session:"
msgstr "Per avviare una sessione:"

#: ../../remote_support.rst:31 62525993ae7545269d6b83443d1b13f8
