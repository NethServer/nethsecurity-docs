msgstr "la sessione sarà attiva per 24 ore per impostazione predefinita"

#: ../../remote_support.rst:33 5d557236ed174b5d91f4ae4f433df0cb
msgid "The system will display:"
msgstr "Il sistema visualizzerà:"

#: ../../remote_support.rst:35 cdf8690f1fef4566889b48df15116761
